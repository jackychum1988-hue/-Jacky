{
  "name": "remotion-realestate",
  "version": "1.0.0",
  "description": "Remotion 房产视频组件库 — 暖金奢华 + 大地色系，专为香港/大湾区房产内容打造",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "upgrade": "remotion upgrade",
    "render-covers": "npx tsx scripts/render-covers.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/three": "^4.0.465",
    "@remotion/transitions": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/three": "^0.184.1",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "vitest": {
    "environment": "jsdom",
    "include": ["test/**/*.test.{ts,tsx}"]
  }
}
